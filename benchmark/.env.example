# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER commit `.env`. NEVER paste keys into chat or issues.

# Required: powers the embedding + summarization layer that creates the
# derived-memory leak the benchmark measures.
OPENAI_API_KEY=sk-replace-me

# Models (override if you want cheaper/different ones)
FERRYTE_BENCH_EMBED_MODEL=text-embedding-3-small
FERRYTE_BENCH_SUMMARY_MODEL=gpt-4o-mini

# Local store endpoints (match docker-compose.yml defaults)
PGVECTOR_DSN=postgresql://ferryte:ferryte@localhost:5432/ferryte
QDRANT_URL=http://localhost:6333
CHROMA_HOST=localhost
CHROMA_PORT=8000

ZEP_API_KEY=z_1dWlkIjoiMTdiOTZjNTAtODViOS00ZDczLThhNzktMTU2NzM2OTNhNGRjIn0.P508KTq_ve4uKnhT9kejKViSAMj0xx67oibxzTbt4m-yPAsnVMN0a0G-Jap5fGtIgXVtIHGOj3ncS7CexNm79Q

# Mem0 runs in-process by default (no server needed).

# AWS Bedrock AgentCore (only needed for the AgentCore backend)
# Credentials come from your AWS CLI profile / env, not from this file.
# Full walkthrough: benchmark/aws_agentcore_setup.md
AWS_REGION=us-west-2
MEMORY_EXECUTION_ROLE_ARN=arn:aws:iam::<acct>:role/AgentCoreMemoryExecRole
# Filled in by `python -m benchmark.setup_agentcore --create`:
# AGENTCORE_MEMORY_ID=
# AGENTCORE_NAMESPACE=/summaries/{actorId}
